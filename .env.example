POSTGRES_DB=cuentas_claras
POSTGRES_USER=cuentas_claras_user
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432
POSTGRES_HOST=postgres
DATABASE_URL=postgresql+psycopg://cuentas_claras_user:change_me@postgres:5432/cuentas_claras

APP_NAME=Cuentas Claras API
APP_ENV=development
BACKEND_PORT=8000
FRONTEND_PORT=5173
CORS_ALLOWED_ORIGINS=http://localhost:5173
SUPPORT_STORAGE_PATH=/app/storage/supports

VITE_API_URL=http://localhost:8000

